{
    "name": "codama-monorepo-test",
    "private": true,
    "scripts": {
        "build": "turbo run build --log-order grouped",
        "lint": "turbo run lint --log-order grouped",
        "lint:fix": "turbo lint:fix --log-order grouped && pnpm prettier --ignore-unknown --write '{.,!packages}/*'",
        "test": "turbo run test --log-order grouped",
        "publish-packages": "pnpm build && changeset publish"
    },
    "devDependencies": {
        "@changesets/changelog-github": "0.5.2",
        "@changesets/cli": "2.29.8",
        "@solana/eslint-config-solana": "5.0.1",
        "@solana/prettier-config-solana": "0.0.6",
        "@types/node": "25.2.3",
        "agadoo": "3.0.0",
        "browserslist-to-esbuild": "2.1.1",
        "eslint": "9.39.2",
        "happy-dom": "20.6.1",
        "prettier": "3.8.1",
        "rimraf": "6.1.3",
        "tsup": "8.5.1",
        "turbo": "2.8.5",
        "typescript": "5.9.3",
        "vitest": "4.0.18"
    },
    "engines": {
        "node": ">=22"
    },
    "packageManager": "pnpm@10.16.1",
    "prettier": "@solana/prettier-config-solana",
    "pnpm": {
        "onlyBuiltDependencies": [
            "litesvm",
            "litesvm-linux-arm64-gnu",
            "litesvm-linux-arm64-musl",
            "litesvm-linux-x64-gnu",
            "litesvm-linux-x64-musl"
        ],
        "overrides": {
            "minimatch@<10.2.1": "10.2.1",
            "rollup@>=4.0.0": "4.59.0",
            "rollup@>=3.0.0 <4.0.0": "3.30.0"
        }
    }
}
