{
    "name": "@hoodieshq/dynamic-instructions",
    "version": "0.0.1",
    "description": "Tool to dynamically build instructions based on Codama IDLs",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/hoodieshq/codama-dynamic-instructions-demo.git",
        "directory": "packages/dynamic-instructions"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "exports": {
        "types": "./dist/types/index.d.ts",
        "react-native": "./dist/index.react-native.mjs",
        "browser": {
            "import": "./dist/index.browser.mjs",
            "require": "./dist/index.browser.cjs"
        },
        "node": {
            "import": "./dist/index.node.mjs",
            "require": "./dist/index.node.cjs"
        }
    },
    "browser": {
        "./dist/index.node.cjs": "./dist/index.browser.cjs",
        "./dist/index.node.mjs": "./dist/index.browser.mjs"
    },
    "main": "./dist/index.node.cjs",
    "module": "./dist/index.node.mjs",
    "react-native": "./dist/index.react-native.mjs",
    "types": "./dist/types/index.d.ts",
    "type": "commonjs",
    "files": [
        "./dist/types",
        "./dist/index.*"
    ],
    "sideEffects": false,
    "keywords": [
        "solana",
        "framework",
        "standard",
        "specifications",
        "parsers"
    ],
    "scripts": {
        "build": "rimraf dist && tsup && tsc -p ./tsconfig.declarations.json",
        "dev": "vitest --project node",
        "lint": "eslint . && prettier --check .",
        "lint:fix": "eslint --fix . && prettier --write .",
        "test": "pnpm test:setup && pnpm test:types && pnpm build && pnpm test:treeshakability && pnpm test:unit",
        "test:setup": "pnpm test:anchor:build && pnpm generate-idl-from-anchor && pnpm generate-program-types",
        "test:anchor:build": "cd tests/anchor && anchor build",
        "test:treeshakability": "for file in dist/index.*.mjs; do test -f \"$file\" || (echo \"Missing build output: $file\" && exit 1); agadoo \"$file\"; done",
        "test:types": "tsc --noEmit",
        "test:unit": "vitest run --pool=threads",
        "generate-idl-from-anchor": "node --experimental-transform-types ./scripts/generate-idl-from-anchor.mts",
        "generate-program-types": "node --experimental-transform-types ./scripts/generate-program-client-types.mts"
    },
    "dependencies": {
        "@codama/dynamic-codecs": "1.1.31",
        "@codama/dynamic-parsers": "1.1.31",
        "@codama/nodes": "1.5.1",
        "@codama/nodes-from-anchor": "1.3.9",
        "@codama/renderers-core": "1.3.6",
        "@codama/renderers-js": "2.0.2",
        "@codama/visitors": "1.5.1",
        "@codama/visitors-core": "1.5.1",
        "@solana/addresses": "5.1.0",
        "@solana/codecs": "5.1.0",
        "@solana/instructions": "5.1.0",
        "@solana/kit": "5.1.0",
        "@solana/web3.js": "1.98.4",
        "codama": "1.5.1",
        "superstruct": "2.0.2"
    },
    "devDependencies": {
        "@metaplex-foundation/mpl-token-metadata-kit": "^0.0.2",
        "@solana-program/program-metadata": "^0.5.1",
        "@solana-program/token": "0.10.0",
        "@solana-program/token-2022": "^0.9.0",
        "@types/bn.js": "5.2.0",
        "litesvm": "0.5.0",
        "sas-lib": "^1.0.10"
    },
    "browserslist": [
        "supports bigint and not dead",
        "maintained node versions"
    ]
}
